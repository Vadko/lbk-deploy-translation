# Copy to `.env` and fill in. `.env` is gitignored.
#
# Run via: pnpm test:local
# (uses @github/local-action to simulate the GitHub Actions runtime)

# Required
INPUT_API-TOKEN=lbk_replaceme_____________________________________
INPUT_GAME-ID=00000000-0000-0000-0000-000000000000
INPUT_VERSION=0.0.1-local-test

# Optional — defaults to https://admin.lbklauncher.com
INPUT_BASE-URL=https://admin.lbklauncher.com

# Archive paths — at least one required. Build a dummy zip first:
#   mkdir -p /tmp/lbk-test && echo "test" > /tmp/lbk-test/dummy.txt
#   (cd /tmp/lbk-test && zip archive.zip dummy.txt)
INPUT_ARCHIVE=/tmp/lbk-test/archive.zip
# INPUT_VOICE=
# INPUT_ACHIEVEMENTS=
# INPUT_EPIC=
# INPUT_GOG=
# INPUT_XBOX=
# INPUT_STEAM-LINUX=
# INPUT_STEAM-MAC=

# Optional metadata
INPUT_STATUS=completed
# INPUT_TRANSLATION-PROGRESS=
# INPUT_EDITING-PROGRESS=
